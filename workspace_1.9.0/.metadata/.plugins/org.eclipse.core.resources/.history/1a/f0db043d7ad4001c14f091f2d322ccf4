#include "stm32f030x8.h"
void delayMs(int n);

int main(void) {
RCC_AHBENR |= 1<<19;/* enable GPIOA clock */
RCC_AHBENR |= 1<<17;
GPIOC_MODER &= ~0x00000030; /* clear pin mode */
GPIOC_MODER |= 0x00000010; /* set pin to output mode */
GPIOC->MODER &= ~0x0C0000000;
while(1) {
	if (GPIOC->IDR & 0x8000)
GPIOC_ODR = 0x00000004; /* turn on LED */

delayMs(500);
    else
GPIOC_ODR = 0x00000200; /* turn off LED */
delayMs(500);
}} /* 16 MHz SYSCLK */
void delayMs(int n) {
int i;
for (; n > 0; n--)
for (i = 0; i < 3195; i++) ;
}




