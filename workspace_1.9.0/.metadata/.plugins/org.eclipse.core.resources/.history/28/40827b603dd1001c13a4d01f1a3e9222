#include <stdint.h>

/***********************************************************************************************************************************************
 *
 *
 *
 *
 * THIS IS A 01 TESTING PROGRAM FOR GPIO LED BLINKING BY SIMPLE ADDRESSESS OF PERIPHERALS
 ***********************************************************************************************************************************************
 ***********************************************************************************************************************************************
#define RCC_AHBENR (*((volatile uint32_t*)0x40021014))
#define GPIOC_MODER (*((volatile uint32_t*)0x48000800))
#define GPIOC_ODR (*((volatile uint32_t*)0x48000814))
void delayMs(int n);
int main(void) {

	RCC_AHBENR |= 1<<19; /* enable GPIOA clock */
GPIOC_MODER &= ~0x00000030; /* clear pin mode */
GPIOC_MODER |= 0x00000010; /* set pin to output mode */
while(1) {
GPIOC_ODR = 0x00000004; /* turn on LED */
delayMs(500);
GPIOC_ODR = 0x00000200; /* turn off LED */
delayMs(500);
}} /* 16 MHz SYSCLK */
void delayMs(int n) {
int i;
for (; n > 0; n--)
for (i = 0; i < 3195; i++) ;
}
